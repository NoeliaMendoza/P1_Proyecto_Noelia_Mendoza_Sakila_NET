@model SakilaApp.Models.PaginatedList<SakilaApp.Models.Rental>
@{
    ViewData["Title"] = "Alquileres";
    var searchString = ViewData["SearchString"] as string ?? "";
    int startPage = Math.Max(1, Model.PageIndex - 2);
    int endPage = Math.Min(Model.TotalPages, startPage + 4);
    if (endPage - startPage < 4) startPage = Math.Max(1, endPage - 4);
}

<h1>Alquileres</h1>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
<div class="row mb-3">
    <div class="col-md-6">
        <form method="get" asp-action="Index" class="d-flex gap-2">
            <input type="text" name="searchString" value="@searchString"
                   class="form-control" placeholder="Buscar por ID de cliente o inventario..." />
            <button type="submit" class="btn btn-secondary">Buscar</button>
            @if (!string.IsNullOrEmpty(searchString))
            {
                <a asp-action="Index" class="btn btn-outline-secondary">✕</a>
            }
        </form>
    </div>
    <div class="col-md-6 text-end">
        <a asp-action="Create" class="btn btn-primary">Crear nuevo</a>
    </div>
</div>

<table class="table table-striped table-bordered">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Fecha alquiler</th>
            <th>ID Inventario</th>
            <th>ID Cliente</th>
            <th>Devolución</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.RentalId</td>
                <td>@item.RentalDate.ToString("dd/MM/yyyy")</td>
                <td>@item.InventoryId</td>
                <td>@item.CustomerId</td>
                <td>@(item.ReturnDate.HasValue ? item.ReturnDate.Value.ToString("dd/MM/yyyy") : "Pendiente")</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.RentalId" class="btn btn-outline-primary btn-sm">Detalles</a>
                    <a asp-action="Edit" asp-route-id="@item.RentalId" class="btn btn-outline-secondary btn-sm">Editar</a>
                    <a asp-action="Delete" asp-route-id="@item.RentalId" class="btn btn-outline-danger btn-sm">Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<nav>
    <ul class="pagination justify-content-center">
        <li class="page-item @(Model.PageIndex == 1 ? "disabled" : "")">
            <a class="page-link" asp-action="Index" asp-route-page="1" asp-route-searchString="@searchString">«</a>
        </li>
        <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
            <a class="page-link" asp-action="Index" asp-route-page="@(Model.PageIndex - 1)" asp-route-searchString="@searchString">‹</a>
        </li>
        @if (startPage > 1)
        {
            <li class="page-item disabled"><span class="page-link">…</span></li>
        }
        @for (int i = startPage; i <= endPage; i++)
        {
            <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-searchString="@searchString">@i</a>
            </li>
        }
        @if (endPage < Model.TotalPages)
        {
            <li class="page-item disabled"><span class="page-link">…</span></li>
        }
        <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
            <a class="page-link" asp-action="Index" asp-route-page="@(Model.PageIndex + 1)" asp-route-searchString="@searchString">›</a>
        </li>
        <li class="page-item @(Model.PageIndex == Model.TotalPages ? "disabled" : "")">
            <a class="page-link" asp-action="Index" asp-route-page="@Model.TotalPages" asp-route-searchString="@searchString">»</a>
        </li>
    </ul>
</nav>
<p class="text-center text-muted small">Página @Model.PageIndex de @Model.TotalPages</p>
