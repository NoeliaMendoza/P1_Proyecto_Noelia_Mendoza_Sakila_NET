@model SakilaApp.Models.Rental
@{
    ViewData["Title"] = "Editar alquiler";
}
<h1>Editar alquiler</h1>
<form asp-action="Edit">
    <input type="hidden" asp-for="RentalId" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="mb-3">
        <label asp-for="RentalDate" class="form-label"></label>
        <input asp-for="RentalDate" class="form-control" type="datetimelocal" />
        <span asp-validation-for="RentalDate" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="InventoryId" class="form-label"></label>
        <input asp-for="InventoryId" class="form-control" />
        <span asp-validation-for="InventoryId" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="CustomerId" class="form-label"></label>
        <input asp-for="CustomerId" class="form-control" />
        <span asp-validation-for="CustomerId" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="ReturnDate" class="form-label"></label>
        <input asp-for="ReturnDate" class="form-control" type="datetimelocal" />
        <span asp-validation-for="ReturnDate" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-warning">Actualizar</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
