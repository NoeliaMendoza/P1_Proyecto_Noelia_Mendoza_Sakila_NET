@model SakilaApp.Models.Customer
@{
    ViewData["Title"] = "Editar cliente";
}

<h1>Editar cliente</h1>
<form asp-action="Edit">
    <input type="hidden" asp-for="CustomerId" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="mb-3">
        <label asp-for="FirstName" class="form-label">Nombre</label>
        <input asp-for="FirstName" class="form-control" />
        <span asp-validation-for="FirstName" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="LastName" class="form-label">Apellido</label>
        <input asp-for="LastName" class="form-control" />
        <span asp-validation-for="LastName" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Email" class="form-label">Email</label>
        <input asp-for="Email" class="form-control" type="email" />
        <span asp-validation-for="Email" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="StoreId" class="form-label">Tienda</label>
        <select asp-for="StoreId" class="form-select" asp-items="ViewBag.Stores">
            <option value="">Seleccione una tienda</option>
        </select>
        <span asp-validation-for="StoreId" class="text-danger"></span>
    </div>
    <input type="hidden" asp-for="AddressId" />
    <div class="mb-3 form-check">
        <input type="checkbox" class="form-check-input" id="activeCheck"
               name="Active" value="1" @(Model.Active == 1 ? "checked" : "") />
        <label class="form-check-label" for="activeCheck">Activo</label>
    </div>
    <button type="submit" class="btn btn-warning">Actualizar</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
