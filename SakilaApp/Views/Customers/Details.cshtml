@model SakilaApp.Models.Customer
@{
    ViewData["Title"] = "Detalles del cliente";
}

<h1>@Model.FirstName @Model.LastName</h1>
<dl class="row">
    <dt class="col-sm-2">ID</dt>
    <dd class="col-sm-10">@Model.CustomerId</dd>
    <dt class="col-sm-2">Nombre</dt>
    <dd class="col-sm-10">@Model.FirstName</dd>
    <dt class="col-sm-2">Apellido</dt>
    <dd class="col-sm-10">@Model.LastName</dd>
    <dt class="col-sm-2">Email</dt>
    <dd class="col-sm-10">@Model.Email</dd>
    <dt class="col-sm-2">Activo</dt>
    <dd class="col-sm-10">@(Model.Active == 1 ? "Sí" : "No")</dd>
    <dt class="col-sm-2">Fecha creación</dt>
    <dd class="col-sm-10">@Model.CreateDate.ToString("dd/MM/yyyy")</dd>
</dl>
<a asp-action="Edit" asp-route-id="@Model.CustomerId" class="btn btn-warning">Editar</a>
<a asp-action="Index" class="btn btn-secondary">Volver</a>
