@model SakilaApp.Models.Store
@{
    ViewData["Title"] = "Eliminar tienda";
}

<h1>Eliminar tienda</h1>
<h3>¿Está seguro de eliminar la tienda #@Model.StoreId?</h3>
<dl class="row">
    <dt class="col-sm-3">ID Manager</dt>
    <dd class="col-sm-9">@Model.ManagerStaffId</dd>
    <dt class="col-sm-3">ID Dirección</dt>
    <dd class="col-sm-9">@Model.AddressId</dd>
    <dt class="col-sm-3">Última actualización</dt>
    <dd class="col-sm-9">@Model.LastUpdate.ToString("dd/MM/yyyy HH:mm")</dd>
</dl>
<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="StoreId" />
    <button type="submit" class="btn btn-danger">Eliminar</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>
