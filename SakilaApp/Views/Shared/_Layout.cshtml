<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - SakilaApp</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
            body { background-color: #f5f5f5; }
            .navbar-brand { font-weight: bold; }
            footer { background-color: #343a40; color: white; padding: 1rem; margin-top: 2rem; text-align: center; }
    </style>
</head>
<body class="d-flex flex-column min-vh-100">
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="/">SakilaApp</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item"><a class="nav-link" href="/Films">Películas</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Actors">Actores</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Categories">Categorías</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Customers">Clientes</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Rentals">Alquileres</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Stores">Tiendas</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Inventories">Inventarios</a></li>
                </ul>
                <ul class="navbar-nav">
                    @if (User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item"><span class="nav-link">Hola, @User.Identity.Name</span></li>
                        <li class="nav-item">
                            <form method="post" action="/Account/Logout">
                                <button class="btn nav-link btn-link">Cerrar sesión</button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item"><a class="nav-link" href="/Account/Register">Registrarse</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Account/Login">Iniciar sesión</a></li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <div class="container mt-4 flex-grow-1">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @RenderBody()
    </div>

    <footer>
        <div class="container">&copy; 2026 - SakilaApp</div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>