@model SakilaApp.Models.Category
@{
    ViewData["Title"] = "Detalles de categoría";
}
<h1>@Model.Name</h1>
<dl class="row">
    <dt class="col-sm-2">ID</dt>
    <dd class="col-sm-10">@Model.CategoryId</dd>
    <dt class="col-sm-2">Nombre</dt>
    <dd class="col-sm-10">@Model.Name</dd>
    <dt class="col-sm-2">Última actualización</dt>
    <dd class="col-sm-10">@Model.LastUpdate</dd>
</dl>
<a asp-action="Edit" asp-route-id="@Model.CategoryId" class="btn btnwarning">Editar</a>
<a asp-action="Index" class="btn btn-secondary">Volver</a>