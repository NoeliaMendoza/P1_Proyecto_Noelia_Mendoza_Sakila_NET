@model SakilaApp.Models.PaginatedList<SakilaApp.Models.Film>
@{
    ViewData["Title"] = "Películas";
    var searchString = ViewData["SearchString"] as string ?? "";

    int maxButtons = 5;
    int half = maxButtons / 2;
    int startPage = Math.Max(1, Model.PageIndex - half);
    int endPage = Math.Min(Model.TotalPages, startPage + maxButtons - 1);
    if (endPage - startPage < maxButtons - 1)
        startPage = Math.Max(1, endPage - maxButtons + 1);
}

<h1>Películas</h1>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row mb-3">
    <div class="col-md-6">
        <form method="get" asp-action="Index" class="d-flex gap-2">
            <input type="text" name="searchString" value="@searchString"
                   class="form-control" placeholder="Buscar por título..." />
            <button type="submit" class="btn btn-secondary">Buscar</button>
            @if (!string.IsNullOrEmpty(searchString))
            {
                <a asp-action="Index" class="btn btn-outline-secondary">✕</a>
            }
        </form>
    </div>
    <div class="col-md-6 text-end">
        <a asp-action="Create" class="btn btn-primary">Crear nueva</a>
    </div>
</div>

<table class="table table-striped table-bordered">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Título</th>
            <th>Año</th>
            <th>Duración</th>
            <th>Tarifa</th>
            <th>Clasificación</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.FilmId</td>
                <td>@item.Title</td>
                <td>@item.ReleaseYear</td>
                <td>@(item.Length ?? 0) min</td>
                <td>$@item.RentalRate</td>
                <td>@item.Rating</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.FilmId" class="btn btn-outline-primary btn-sm">Detalles</a>
                    <a asp-action="Edit" asp-route-id="@item.FilmId" class="btn btn-outline-secondary btn-sm">Editar</a>
                    <a asp-action="Delete" asp-route-id="@item.FilmId" class="btn btn-outline-danger btn-sm">Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<nav aria-label="Paginación">
    <ul class="pagination justify-content-center flex-wrap">

        <li class="page-item @(Model.PageIndex == 1 ? "disabled" : "")">
            <a class="page-link" asp-action="Index"
               asp-route-pageNumber="1"
               asp-route-searchString="@searchString" title="Primera">«</a>
        </li>

        <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
            <a class="page-link" asp-action="Index"
               asp-route-pageNumber="@(Model.PageIndex - 1)"
               asp-route-searchString="@searchString">‹</a>
        </li>

        @if (startPage > 1)
        {
            <li class="page-item disabled"><span class="page-link">…</span></li>
        }

        @for (int i = startPage; i <= endPage; i++)
        {
            <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                <a class="page-link" asp-action="Index"
                   asp-route-pageNumber="@i"
                   asp-route-searchString="@searchString">@i</a>
            </li>
        }

        @if (endPage < Model.TotalPages)
        {
            <li class="page-item disabled"><span class="page-link">…</span></li>
        }

        <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
            <a class="page-link" asp-action="Index"
               asp-route-pageNumber="@(Model.PageIndex + 1)"
               asp-route-searchString="@searchString">›</a>
        </li>

        <li class="page-item @(Model.PageIndex == Model.TotalPages ? "disabled" : "")">
            <a class="page-link" asp-action="Index"
               asp-route-pageNumber="@Model.TotalPages"
               asp-route-searchString="@searchString" title="Última">»</a>
        </li>

    </ul>
</nav>

<p class="text-center text-muted small">
    Página @Model.PageIndex de @Model.TotalPages
</p>
